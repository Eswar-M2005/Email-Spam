# ── Python ───────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
venv*/
env/
.venv/
*.egg-info/
dist/
build/
.eggs/

# ── Environment variables (NEVER commit secrets) ──────────────────────
.env
.env.local
.env.*.local
frontend/.env

# ── Node / Frontend ───────────────────────────────────────────────────
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.vite/
*.tsbuildinfo

# ── macOS ─────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── IDEs ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Firebase / Google credentials ─────────────────────────────────────
serviceAccountKey.json
*-firebase-adminsdk-*.json
firebase-credentials.json
client_secret*.json
credentials.json
token.json

# ── ML model (regenerated by train_model.py) ─────────────────────────
# Uncomment to exclude large pkl files from git:
# backend/model/*.pkl

# ── Logs ─────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*

# ── Test artifacts ────────────────────────────────────────────────────
.pytest_cache/
htmlcov/
.coverage
