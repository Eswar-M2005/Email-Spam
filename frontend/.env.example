# Firebase (from Firebase Console → Project Settings → Web App)
VITE_FIREBASE_API_KEY=AIza...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000:web:000

# Backend API URL (leave empty to use Vite proxy in dev)
VITE_API_URL=
# Production: VITE_API_URL=https://your-backend.onrender.com/api
